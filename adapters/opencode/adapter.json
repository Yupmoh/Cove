{
  "sdkVersion": 2,
  "name": "opencode",
  "displayName": "opencode",
  "description": "Open-source terminal agent with LSP integration and a client/server split. Bring your own provider.",
  "accent": "#94e2d5",
  "binary": "opencode",
  "version": "1.0.0",
  "author": "Cove",
  "skillInstallPath": "~/.agents/skills/cove/SKILL.md",
  "skillsDir": "~/.agents/skills",
  "binaryDiscovery": {
    "commands": [
      "opencode"
    ],
    "versionFlag": "--version",
    "versionRegex": "(\\d+\\.\\d+\\.\\d+)"
  },
  "packageIdentity": { "npm": "opencode-ai" },
  "install": {
    "macos": {
      "cmd": "npm install -g --allow-scripts=opencode-ai opencode-ai@latest"
    },
    "linux": {
      "cmd": "npm install -g --allow-scripts=opencode-ai opencode-ai@latest"
    },
    "windows": {
      "cmd": "npm install -g --allow-scripts=opencode-ai opencode-ai@latest"
    }
  },
  "methods": {},
  "screenState": {
    "quietMs": 2500,
    "rules": [
      {
        "pattern": "(?im)(allow|approve|grant|permission).{0,80}(y/n|yes/no|\\[y|\\(y\\))",
        "status": "needs-permission"
      },
      {
        "pattern": "(?im)^.{0,120}(\\(y/n\\)|\\[y/n\\]|\\[y/N\\]|press (enter|y) to)",
        "status": "needs-input"
      },
      {
        "pattern": "(?i)(esc to interrupt|ctrl\\+c to (cancel|interrupt)|thinking|working\\.{2,3})",
        "status": "active"
      }
    ]
  }
}
