{
  "sdkVersion": 2,
  "name": "hermes",
  "displayName": "Hermes",
  "description": "Nous Research's terminal agent built around the open-weight Hermes model family.",
  "accent": "#f9e2af",
  "binary": "hermes",
  "version": "1.0.0",
  "author": "Cove",
  "skillInstallPath": "~/.hermes/skills/cove/SKILL.md",
  "skillsDir": "~/.hermes/skills",
  "binaryDiscovery": {
    "commands": [
      "hermes"
    ],
    "wellKnownPaths": [
      "~/.local/bin",
      "/opt/homebrew/bin",
      "/usr/local/bin"
    ],
    "versionFlag": "--version",
    "versionRegex": "(\\d+\\.\\d+\\.\\d+)"
  },
  "install": {
    "macos": {
      "cmd": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash"
    },
    "linux": {
      "cmd": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash"
    }
  },
  "update": {
    "macos": {
      "cmd": "hermes update"
    },
    "linux": {
      "cmd": "hermes update"
    }
  },
  "uninstall": {
    "macos": {
      "cmd": "hermes uninstall"
    },
    "linux": {
      "cmd": "hermes uninstall"
    }
  },
  "methods": {},
  "screenState": {
    "quietMs": 2500,
    "rules": [
      {
        "pattern": "(?im)(allow|approve|grant|permission).{0,80}(y/n|yes/no|\\[y|\\(y\\))",
        "status": "needs-permission"
      },
      {
        "pattern": "(?im)^.{0,120}(\\(y/n\\)|\\[y/n\\]|\\[y/N\\]|press (enter|y) to)",
        "status": "needs-input"
      },
      {
        "pattern": "(?i)(esc to interrupt|ctrl\\+c to (cancel|interrupt)|thinking|working\\.{2,3})",
        "status": "active"
      }
    ]
  }
}
