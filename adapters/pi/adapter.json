{
  "sdkVersion": 2,
  "name": "pi",
  "displayName": "pi",
  "description": "Minimal coding agent with a tiny readable core. The easiest harness to understand and modify.",
  "accent": "#f5c2e7",
  "binary": "pi",
  "version": "1.0.0",
  "author": "Cove",
  "skillInstallPath": "~/.agents/skills/cove/SKILL.md",
  "skillsDir": "~/.agents/skills",
  "binaryDiscovery": {
    "commands": [
      "pi"
    ],
    "versionFlag": "--version",
    "versionRegex": "(\\d+\\.\\d+\\.\\d+)"
  },
  "packageIdentity": { "npm": "@earendil-works/pi-coding-agent" },
  "install": {
    "macos": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent@latest"
    },
    "linux": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent@latest"
    },
    "windows": {
      "cmd": "npm install -g --ignore-scripts @earendil-works/pi-coding-agent@latest"
    }
  },
  "methods": {},
  "screenState": {
    "quietMs": 2500,
    "rules": [
      {
        "pattern": "(?im)(allow|approve|grant|permission).{0,80}(y/n|yes/no|\\[y|\\(y\\))",
        "status": "needs-permission"
      },
      {
        "pattern": "(?im)^.{0,120}(\\(y/n\\)|\\[y/n\\]|\\[y/N\\]|press (enter|y) to)",
        "status": "needs-input"
      },
      {
        "pattern": "(?i)(esc to interrupt|ctrl\\+c to (cancel|interrupt)|thinking|working\\.{2,3})",
        "status": "active"
      }
    ]
  }
}
