{
  "sdkVersion": 2,
  "name": "omp",
  "displayName": "omp",
  "description": "oh-my-pi: hackable, provider-agnostic harness. Run any model, share sessions live, extend with custom tools and hooks.",
  "accent": "#cba6f7",
  "binary": "omp",
  "version": "1.0.0",
  "author": "Cove",
  "skillInstallPath": "~/.omp/agent/skills/cove/SKILL.md",
  "skillsDir": "~/.omp/agent/skills",
  "binaryDiscovery": {
    "commands": ["omp"],
    "versionFlag": "--version",
    "versionRegex": "(\\d+\\.\\d+\\.\\d+)"
  },
  "packageIdentity": { "npm": "@oh-my-pi/pi-coding-agent" },
  "hooks": {
    "session-start": "cove://hooks/omp/session-start",
    "session-end": "cove://hooks/omp/session-end",
    "user-prompt-submit": "cove://hooks/omp/user-prompt-submit",
    "pre-tool-use": "cove://hooks/omp/pre-tool-use",
    "post-tool-use": "cove://hooks/omp/post-tool-use",
    "notification": "cove://hooks/omp/notification",
    "stop": "cove://hooks/omp/stop"
  },
  "methods": {
    "list_recent_sessions": { "script": "list_recent_sessions.sh" },
    "build_launch_command": { "script": "build_launch_command.sh" },
    "build_resume_command": { "script": "build_resume_command.sh" },
    "launcher_options": { "static": "launcher_options.json" }
  }
}
