{
  "sdkVersion": 2,
  "name": "codex",
  "displayName": "Codex",
  "description": "OpenAI's coding agent. GPT models with sandboxed command execution and a fast full-auto mode.",
  "accent": "#a6e3a1",
  "binary": "codex",
  "version": "1.0.0",
  "author": "Cove",
  "skillInstallPath": "~/.agents/skills/cove/SKILL.md",
  "skillsDir": "~/.agents/skills",
  "binaryDiscovery": {
    "commands": ["codex"],
    "versionFlag": "--version",
    "versionRegex": "(\\d+\\.\\d+\\.\\d+)"
  },
  "packageIdentity": { "npm": "@openai/codex" },
  "hooks": {
    "session-start": "cove://hooks/codex/session-start",
    "user-prompt-submit": "cove://hooks/codex/user-prompt-submit",
    "pre-tool-use": "cove://hooks/codex/pre-tool-use",
    "post-tool-use": "cove://hooks/codex/post-tool-use",
    "permission-request": "cove://hooks/codex/permission-request",
    "subagent-start": "cove://hooks/codex/subagent-start",
    "subagent-stop": "cove://hooks/codex/subagent-stop",
    "stop": "cove://hooks/codex/stop"
  },
  "methods": {
    "list_recent_sessions": { "script": "list_recent_sessions.sh" },
    "build_launch_command": { "script": "build_launch_command.sh" },
    "build_resume_command": { "script": "build_resume_command.sh" },
    "launcher_options": { "static": "launcher_options.json" }
  }
}
